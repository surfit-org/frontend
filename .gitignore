# ---------------------------------------------------------------------------
# 1. OS & Logs (시스템 및 로그)
# ---------------------------------------------------------------------------
.DS_Store
*.log
logs
npm-debug.*
yarn-debug.*
yarn-error.*
lerna-debug.log*

# ---------------------------------------------------------------------------
# 2. Dependencies (의존성 패키지)
# ---------------------------------------------------------------------------
node_modules/
jspm_packages/
web_modules/
bower_components/

# ---------------------------------------------------------------------------
# 3. Expo & React Native (핵심 설정)
# ---------------------------------------------------------------------------
.expo/
dist/
web-build/
expo-env.d.ts
app-example/
.metro-health-check*

# 생성된 네이티브 폴더 (직접 수정하지 않는 경우)
/ios
/android

# Native keys & provisions (보안상 절대 금지)
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ---------------------------------------------------------------------------
# 4. Environment Variables (환경 변수 - 보안 필수!)
# ---------------------------------------------------------------------------
.env
.env.*
.env*.local
# .env.example은 예시 파일이므로 추적 허용
!.env.example

# ---------------------------------------------------------------------------
# 5. Build & Cache (빌드 및 캐시)
# ---------------------------------------------------------------------------
build/
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
.cache
.parcel-cache
.node_repl_history
.yarn-integrity
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ---------------------------------------------------------------------------
# 6. 기타 도구 (Optional)
# ---------------------------------------------------------------------------
coverage/
.nyc_output
.vscode-test
.serverless/